    {"element_id": "odd.targets.non_motor_vehicle", "requirement": "permitted", "description": "自行车、电动车（中国城市混合交通必需）"},
    {"element_id": "odd.targets.pedestrian", "requirement": "permitted"},
    {"element_id": "odd.targets.animal", "requirement": "permitted"},
    {"element_id": "odd.targets.obstacle", "requirement": "permitted", "description": "锥桶、路障识别"},

