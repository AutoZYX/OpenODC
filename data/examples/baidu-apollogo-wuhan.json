    {"element_id": "odd.road.lane.type.bus", "requirement": "not_permitted", "exit_behavior": "suppress_activation"},
    {"element_id": "odd.road.lane.type.emergency", "requirement": "not_permitted", "exit_behavior": "suppress_activation"},

