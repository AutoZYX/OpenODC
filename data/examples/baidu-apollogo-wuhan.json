    {"element_id": "odd.road.type.urban_road.sub_arterial", "requirement": "permitted"},
    {"element_id": "odd.road.type.urban_road.branch", "requirement": "not_permitted", "description": "支路与居住小区内部未开放", "exit_behavior": "suppress_and_exit"},
    {"element_id": "odd.road.type.highway.expressway", "requirement": "permitted", "description": "围栏内部分高速路段，限速 70-80 km/h"},
