  "elements": [
    {"element_id": "odd.road.type.area", "requirement": "permitted", "description": "武汉地理围栏运营区（约 3000 km²，覆盖武汉经开区/武昌/汉阳/硚口/东西湖/蔡甸/洪山/江夏）"},
