    {"element_id": "odd.weather.atmospheric.snow.snowfall", "requirement": "not_permitted", "description": "暴雪触发服务暂停", "exit_behavior": "suppress_activation"},
    {"element_id": "odd.weather.lighting.natural", "requirement": "permitted"},
    {"element_id": "odd.weather.lighting.streetlight", "requirement": "permitted"},
    {"element_id": "odd.weather.lighting.headlight", "requirement": "permitted", "description": "24 小时运营已在部分区域开通"},

    {"element_id": "odd.digital.wireless.v2i", "requirement": "permitted", "description": "V2I 信号灯通信"},
    {"element_id": "odd.digital.wireless.v2v", "requirement": "permitted"},
    {"element_id": "odd.digital.position.gnss", "requirement": "permitted", "description": "BDS + GPS 组合定位"},
    {"element_id": "odd.digital.position.rtk", "requirement": "permitted", "description": "RTK 高精度定位"},

    {"element_id": "vehicle.motion.speed.activation", "requirement": "permitted", "parameter_range": "0 km/h ~ 80 km/h"},
    {"element_id": "vehicle.motion.speed.operating", "requirement": "permitted", "parameter_range": "0 km/h ~ 80 km/h"},

    {"element_id": "vehicle.ads_state", "requirement": "permitted", "description": "HD 地图、多传感器健康、远程监控连接均正常；任一异常则返回最近停靠点或远程接管"}
